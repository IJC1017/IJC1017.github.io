---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="会社概要 | 王子建設不動産"
  currentPage="intro"
>
  <style>
    .intro-page-container {
      display: flex;
      max-width: 1200px;
      margin: 50px auto;
      background: #fff;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      border-radius: 8px;
      overflow: hidden;
      flex-wrap: wrap;
    }
    .intro-info-section {
      flex: 1;
      padding: 40px;
      background: #2c3e50;
      color: white;
    }
    .intro-info-section h2 {
      font-size: 1.8rem;
      margin-top: 0;
      border-bottom: 2px solid #f39c12;
      padding-bottom: 10px;
    }
    .intro-info-section ul {
      list-style: none;
      padding: 0;
    }
    .intro-info-section li {
      margin-bottom: 25px;
      display: flex;
      align-items: flex-start;
    }
    .intro-info-section .icon {
      margin-right: 15px;
      font-size: 1.5rem;
      color: #f39c12;
      flex-shrink: 0;
    }
    .intro-info-section .text-block p {
      margin: 0;
      padding: 0;
    }
    .intro-content-section {
      flex: 2;
      padding: 40px;
    }
    .intro-content-section h2 {
      font-size: 1.8rem;
      margin-top: 0;
      border-bottom: 2px solid #3498db;
      padding-bottom: 10px;
      text-align: left;
    }
    .intro-content-section .info-list {
      list-style: none;
      padding: 0;
    }
    .intro-content-section .info-list li {
      margin-bottom: 15px;
    }
    .intro-content-section .info-list li strong {
      display: block;
      margin-bottom: 5px;
      font-size: 1.1rem;
      color: #2c3e50;
    }
    .intro-content-section .info-list li p {
      margin: 0;
    }
    .intro-content-section img {
      width: 100%;
      height: auto;
      border-radius: 8px;
      margin-bottom: 20px;
    }

    @media (max-width: 768px) {
      .intro-page-container {
        flex-direction: column;
        margin: 20px;
      }
      .intro-info-section, .intro-content-section {
        padding: 30px;
      }
    }
  </style>

  <div class="intro-page-container">
    <div class="intro-info-section">
      <h2>イノベーション情報株式会社</h2>
      <ul>
        <li>
          <span class="material-symbols-outlined icon">apartment</span>
          <div class="text-block">
            <p>会社名</p>
            <p>株式会社 イノベーション情報株式会社</p>
          </div>
        </li>
        <li>
          <span class="material-symbols-outlined icon">location_on</span>
          <div class="text-block">
            <p>住所</p>
            <p>〒111-0052</p>
            <p>東京都台東区柳橋2-2-3 西田ビル 2F</p>
          </div>
        </li>
        <li>
          <span class="material-symbols-outlined icon">call</span>
          <div class="text-block">
            <p>TEL 03-5829-3548</p>
            <p>FAX 03-5829-3481</p>
            <p>080-4432-8883</p>
          </div>
        </li>
        <li>
          <span class="material-symbols-outlined icon">mail</span>
          <div class="text-block">
            <p>Email</p>
            <p>ijc.info1017@gmail.com(代表)</p>
            <p>ijc.watanabe@gmail.com</p>
          </div>
        </li>
        <li>
          <span class="material-symbols-outlined icon">schedule</span>
          <div class="text-block">
            <p>営業時間</p>
            <p>9:00 - 18:00</p>
          </div>
        </li>
      </ul>
    </div>
    <div class="intro-content-section">
      <img src="/assists/images/company_profile.jpg" alt="会社イメージ" />
      <h2>会社概要</h2>
      <ul class="info-list">
        <li>
          <strong>会社名</strong>
          <p>株式会社 王子建設不動産</p>
        </li>
        <li>
          <strong>住所</strong>
          <p>〒111-0052 東京都台東区柳橋2-2-3 西田ビル 2F</p>
        </li>
        <li>
          <strong>TEL</strong>
          <p>03-5829-3548</p>
        </li>
        <li>
          <strong>FAX</strong>
          <p>03-5829-3481</p>
        </li>
        <li>
          <strong>Email</strong>
          <p>ijc.info1017@gmail.com(代表)</p>
          <p>ijc.watanabe@gmail.com</p>
        </li>
        <li>
          <strong>設立</strong>
          <p>令和1年10月17日</p>
        </li>
        <li>
          <strong>代表者名</strong>
          <p>渡辺晶子</p>
        </li>
        <li>
          <strong>資本金</strong>
          <p>500万円</p>
        </li>
        <li>
          <strong>業務内容</strong>
          <p>不動産の買取・売買・賃貸・管理、リフォーム・内装工事、留学エージェント</p>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
