---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="イノベーション情報株式会社（王子建設不動産） - 理想の住まいをトータルサポート"
  description="不動産・建築などのことならイノベーション情報株式会社にお任せください。"
  currentPage="home"
>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "王子建設不動産",
      "legalName": "イノベーション情報株式会社",
      "url": "www.ijc1017.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "柳橋2-2-3 西田ビル 2F",
        "addressLocality": "台東区",
        "addressRegion": "東京都",
        "postalCode": "111-0052",
        "addressCountry": "JP"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+81-3-5829-3548",
        "contactType": "customer service"
      }
    }
  </script>

  <style>
    .hero {
      background: url('/assists/images/tokyo_bg.jpg') no-repeat center center/cover;
      filter: grayscale(15%);
      color: white;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
      height: 100vh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      position: relative;
      opacity: 0;
      transition: opacity 1.5s ease-in;
      box-sizing: border-box;
    }
    .hero.is-visible { opacity: 1; }
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.3);
      z-index: 1;
    }
    .hero h1, .hero p {
      position: relative;
      z-index: 2;
    }
    .hero h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
    }
    .hero p {
      font-size: 1.2rem;
      max-width: 800px;
      line-height: 1.9;
      text-align: center;
    }
    .hero h1 br { display: none; }

    #about, #dynamic-services, #department-intro, #company-info-anchor {
      scroll-margin-top: 170px;
    }

    /* Sections */
    .section {
      padding: 50px 5%;
      margin-bottom: 20px;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
      position: relative;
      overflow: hidden;
    }
    .section.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .section:nth-of-type(odd) { background-color: #fff; }
    .section:nth-of-type(even) { background-color: #f9f9f9; }

    .section h2 {
      text-align: center;
      font-size: 2.2rem;
      margin-bottom: 40px;
      padding-bottom: 8px;
      font-weight: normal;
      letter-spacing: 1px;
      width: 100%;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }
    .section h2::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 0;
      height: 3px;
      background-color: #3498db;
      transition: width 0.6s ease-out;
    }
    .section.is-visible h2::after {
      width: 80%;
      max-width: 400px;
    }

    /* About */
    #about .grid {
      display: block;
      max-width: 800px;
      margin: auto;
      text-align: center;
    }
    .about-us-container {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      margin-bottom: 30px;
    }
    .about-us-container img {
      width: 100%;
      height: 100%;
      border-radius: 8px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      object-fit: cover;
      filter: grayscale(10%);
      transition: transform 0.5s ease-in-out, filter 0.5s ease-in-out;
    }
    .about-us-container img:hover { transform: scale(1.05); filter: grayscale(0%); }
    .about-us-text { max-width: 700px; margin: auto; }
    .about-us-text p {
      text-align: justify;
      margin-bottom: 15px;
      font-size: 1.05rem;
      padding: 0 10px;
      line-height: 1.9;
    }
    .about-us-text h3 {
      font-size: 1.5rem;
      color: #f39c12;
      margin-bottom: 20px;
      text-decoration: underline;
      text-decoration-color: #3498db;
      text-underline-offset: 5px;
      font-weight: normal;
    }
    .img-zoom-container {
      overflow: hidden;
      border-radius: 8px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
      width: 600px;
      height: 450px;
      margin: auto;
    }

    /* Department items */
    .department-item {
      display: flex;
      align-items: center;
      margin-bottom: 60px;
      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;
      gap: 40px;
    }
    .department-item:nth-child(even) { flex-direction: row-reverse; }
    .department-image { flex: 1; min-width: 350px; }
    .department-image img {
      width: 100%;
      height: 320px;
      object-fit: cover;
      border-radius: 8px;
      filter: grayscale(20%);
      transition: transform 0.5s ease-in-out;
    }
    .department-image img:hover { transform: scale(1.15); }
    .department-text { flex: 1; padding: 20px 0; }
    .department-text h3 {
      font-size: 1.6rem;
      color: #2980b9;
      border-left: 4px solid #f39c12;
      padding-left: 10px;
      margin-top: 0;
      margin-bottom: 15px;
    }
    .department-text p {
      font-size: 1rem;
      text-align: justify;
      line-height: 1.9;
    }
    #department-intro .img-zoom-container {
      width: 100%;
      height: 320px;
      margin: 0;
    }

    /* Dynamic Services */
    #dynamic-services {
      padding: 0;
      margin-bottom: 20px;
      position: relative;
    }
    .service-intro-text {
      text-align: center;
      max-width: 800px;
      margin: -20px auto 40px auto;
      padding: 10px 0;
      font-size: 1.1rem;
      color: #555;
      border-bottom: 1px solid #ddd;
      line-height: 1.9;
    }
    .service-container {
      display: flex;
      width: 100%;
      height: 450px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }
    .service-item {
      flex: 1;
      position: relative;
      overflow: hidden;
      color: white;
      text-align: center;
      cursor: pointer;
      transition: flex-grow 0.5s ease-in-out;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }
    .service-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      transition: transform 0.5s ease-in-out, filter 0.5s ease-in-out;
      z-index: 1;
      filter: brightness(0.6) grayscale(0.8);
    }
    /* When hovering the container, shrink all items equally */
    .service-container:hover .service-item {
      flex-grow: 0.6;
    }
    /* Override: expand the currently hovered item (~1.5x) */
    .service-container .service-item:hover {
      flex-grow: 1.1;
    }
    .service-item:hover::before, .service-item.is-active::before {
      transform: scale(1.15);
      filter: brightness(0.8) grayscale(0);
    }
    .service-content {
      position: relative;
      z-index: 2;
      max-width: 80%;
      transition: opacity 0.3s ease-in-out;
    }
    .service-title {
      font-size: 1.6rem;
      font-weight: bold;
      margin-bottom: 10px;
      border-bottom: 2px solid white;
      padding-bottom: 5px;
      display: inline-block;
    }
    .service-intro {
      font-size: 0.9rem;
      opacity: 0;
      height: 0;
      overflow: hidden;
      transition: opacity 0.5s ease-in-out, height 0.5s ease-in-out;
      line-height: 1.7;
    }
    .service-item:hover .service-intro, .service-item.is-active .service-intro {
      opacity: 1;
      height: auto;
      padding-top: 10px;
    }
    .service-item[data-bg-url]::before { background-image: var(--bg-url); }

    /* Image Nav Bar */
    .image-nav-container {
      display: flex;
      width: 100%;
      background-color: #fff;
    }
    .image-nav-item {
      flex: 1;
      position: relative;
      height: 280px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: white;
    }
    .image-nav-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      transition: transform 0.4s ease, filter 0.4s ease;
      z-index: 1;
    }
    .image-nav-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.4);
      z-index: 2;
      transition: background-color 0.4s ease;
    }
    .image-nav-item:hover .image-nav-bg { transform: scale(1.1); filter: brightness(1.2); }
    .image-nav-item:hover::before { background-color: rgba(41, 128, 185, 0.6); }
    .image-nav-text {
      position: relative;
      z-index: 3;
      text-align: center;
      text-shadow: 1px 1px 3px rgba(0,0,0,0.6);
    }
    .image-nav-text .nav-text-main {
      display: block;
      font-size: 1.7rem;
      font-weight: bold;
      letter-spacing: 1px;
    }
    .image-nav-text .nav-text-sub {
      display: block;
      font-size: 1rem;
      margin-top: 5px;
    }

    /* ----- Responsive ----- */
    @media (max-width: 1024px) {
      .service-container { flex-direction: column; height: auto; }
      .service-item { flex-grow: 1 !important; height: 420px; }
      .department-item { flex-direction: column !important; }
      .department-image { min-width: 100%; height: 250px; }
      #department-intro .img-zoom-container, .department-image img { height: 100%; }
      .service-item:hover::before, .service-item.is-active::before {
        transform: scale(1.05);
        filter: brightness(0.8) grayscale(0);
      }
      #about .img-zoom-container { width: 100%; height: 300px; }
    }

    @media (max-width: 768px) {
      #about, #dynamic-services, #department-intro, #company-info-anchor {
        scroll-margin-top: 90px;
      }
      .hero {
        padding-left: 25px;
        padding-right: 25px;
        text-align: center;
      }
      .hero h1 { font-size: 2.2rem; }
      .hero p { font-size: 1rem; }
      .hero h1 br { display: block; }
      .service-item { height: auto; min-height: 52vw; max-height: 75vh; }
      .image-nav-container { flex-direction: column; }
      .image-nav-item { height: 200px; }
      .about-us-text p { text-align: left; }
      #about .about-us-container img { width: 100%; height: 100%; }
      .img-zoom-container { width: 90%; height: 200px; }
      .grid, .about-us-container { flex-direction: column; }
      .service-intro-text { margin: -20px 20px 40px 20px; }
    }
  </style>

  <!-- Hero -->
  <div class="hero">
    <h1>挑戦する人のそばに、<br />いつも私たちがいる</h1>
    <p>
      私たちは、不動産・リフォーム・留学事業を通じて、人々の新しい暮らしと学びをサポートしています。「人の役に立つ会社」であることを大切に、安心して暮らせる社会づくりに貢献してまいります。
    </p>
  </div>

  <div class="section-container">
    <!-- About -->
    <section id="about" class="section">
      <div class="grid">
        <h2>会社概要</h2>
        <div class="about-us-container">
          <div class="img-zoom-container">
            <img src="/assists/images/re_info.jpg" alt="会社イメージ画像" />
          </div>
          <div class="about-us-text">
            <h3>私たちの想い (Our Philosophy)</h3>
            <p>私たちは2019年に設立し、外国人留学生の支援を原点として事業を展開してまいりました。現在は、不動産・リフォーム・留学エージェントの3つの事業を柱に、日本で暮らしや学びを始める方々を幅広くサポートしています。</p>
            <p>住まい探しから生活立ち上げ、学びや進路の相談まで、安心して挑戦できる環境をワンストップで提供できるのが私たちの強みです。</p>
            <p>「人の役に立つ会社」であることを理念に掲げ、日本と海外をつなぐ架け橋として、これからも多様な人々の挑戦を支え続けてまいります。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Dynamic Services -->
    <section id="dynamic-services" class="section">
      <h2 style="max-width: 100%;">事業内容</h2>
      <div class="service-container">
        <div class="service-item" data-bg-url="/assists/images/tokyo_white.jpg">
          <div class="service-content">
            <div class="service-title">不動産事業</div>
            <p class="service-intro">買取・売買・賃貸・管理に幅広く対応。外国籍のお客様にも安心いただけるよう、住まい探しから生活立ち上げまでトータルにサポートします。</p>
          </div>
        </div>
        <div class="service-item" data-bg-url="/assists/images/renovation_1.jpeg">
          <div class="service-content">
            <div class="service-title">リフォーム事業</div>
            <p class="service-intro">物件購入や賃貸とあわせてリフォーム・内装工事をご提案。経験豊富な職人の確かな技術とグループ会社ならではの価格で快適な住まいを実現します。</p>
          </div>
        </div>
        <div class="service-item" data-bg-url="/assists/images/Tokyo_University_4.jpg">
          <div class="service-content">
            <div class="service-title">留学エージェント事業</div>
            <p class="service-intro">設立以来、多くの外国人留学生を日本へ紹介。現地確認に基づく教育機関の紹介と、生活面まで支える安心サポートで新しい挑戦を応援します。</p>
          </div>
        </div>
        <div class="service-item" data-bg-url="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=800&h=600&fit=crop&q=80">
          <div class="service-content">
            <div class="service-title">有料職業紹介事業</div>
            <p class="service-intro">留学生の卒業後の進路を支援するため、有料職業紹介事業を展開。企業との幅広いネットワークを活かし、一人ひとりの適性や希望に合った就職先を紹介します。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Department Intro -->
    <section id="department-intro" class="section">
      <h2 style="max-width: 100%;">事業紹介</h2>
      <div class="department-item">
        <div class="department-text">
          <h3>不動産事業</h3>
          <p>弊社は、不動産の買取・売買・賃貸・管理を中心に、お客様一人ひとりのニーズに合わせた住まい探しを行っております。単なる物件紹介にとどまらず、引っ越しサポートや中古家具・家電の販売など、生活立ち上げに必要なサービスをワンストップで提供しています。特に外国籍のお客様が多く、留学生や外国人にとって大きな不安となる「言葉の壁」「住まい探し」「生活立ち上げ」をサポートし、日本で安心して暮らしを始められるよう支援しています。</p>
        </div>
        <div class="department-image">
          <div class="img-zoom-container">
            <img src="/assists/images/real_estate.jpeg" alt="不動産事業イメージ画像" />
          </div>
        </div>
      </div>
      <div class="department-item">
        <div class="department-text">
          <h3>リフォーム事業</h3>
          <p>弊社にはリフォーム・内装工事を専門に担うグループ会社があり、物件の購入や賃貸とあわせてリフォームをご提案することができます。入居前のリノベーションから部分的な修繕まで幅広く対応可能で、経験豊富な職人による確かな仕上がりをお約束します。グループ会社との連携により価格面でも安心してご利用いただけるのが大きな強みです。</p>
        </div>
        <div class="department-image">
          <div class="img-zoom-container">
            <img src="/assists/images/decoration.jpg" alt="リフォーム事業イメージ画像" />
          </div>
        </div>
      </div>
      <div class="department-item">
        <div class="department-text">
          <h3>留学エージェント事業</h3>
          <p>弊社は2019年の設立以来、留学エージェントとして多くの外国人留学生を日本へ紹介し、学びと生活の両面を支援してきました。学生一人ひとりの希望や将来の目標を丁寧に伺い、最適な教育機関をご紹介いたします。ご紹介する教育機関は、必ず弊社スタッフが現地に足を運び、特色や教育環境を理解したうえでご案内しています。単なる学校紹介にとどまらず、卒業後の進学・就職を見据えたアドバイスを行い、学生と教育機関双方にとって満足度の高い出会いを実現しています。</p>
        </div>
        <div class="department-image">
          <div class="img-zoom-container">
            <img src="/assists/images/foreigner.jpg" alt="留学エージェント事業イメージ画像" />
          </div>
        </div>
      </div>
      <div class="department-item">
        <div class="department-image">
          <div class="img-zoom-container">
            <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=800&h=600&fit=crop&q=80" alt="有料職業紹介事業イメージ画像" />
          </div>
        </div>
        <div class="department-text">
          <h3>有料職業紹介事業</h3>
          <p>弊社は、留学生の卒業後の就職支援を強化するため、有料職業紹介事業を展開しています。長年の留学生支援で培った教育機関や企業とのネットワークを活かし、求職者一人ひとりの語学力や専門性、希望条件に寄り添った求人を紹介します。単なるマッチングではなく、履歴書の書き方や面接対策などの実践的なサポートも提供し、日本でのキャリア形成をトータルに支援しています。</p>
        </div>
      </div>
    </section>
  </div>

  <!-- Image Nav Bar -->
  <div class="image-nav-container">
    <a href="/#about" class="image-nav-item">
      <div class="image-nav-bg" style="background-image: url('https://picsum.photos/800/600?random=30');"></div>
      <div class="image-nav-text">
        <span class="nav-text-main">COMPANY</span>
        <span class="nav-text-sub">会社案内</span>
      </div>
    </a>
    <a href="/#dynamic-services" class="image-nav-item">
      <div class="image-nav-bg" style="background-image: url('https://picsum.photos/800/600?random=31');"></div>
      <div class="image-nav-text">
        <span class="nav-text-main">SERVICE</span>
        <span class="nav-text-sub">事業内容</span>
      </div>
    </a>
    <a href="/#company-info-anchor" class="image-nav-item">
      <div class="image-nav-bg" style="background-image: url('https://picsum.photos/800/600?random=32');"></div>
      <div class="image-nav-text">
        <span class="nav-text-main">ACCESS</span>
        <span class="nav-text-sub">アクセス</span>
      </div>
    </a>
    <a href="/contact" class="image-nav-item">
      <div class="image-nav-bg" style="background-image: url('https://picsum.photos/800/600?random=33');"></div>
      <div class="image-nav-text">
        <span class="nav-text-main">CONTACT</span>
        <span class="nav-text-sub">お問合せ</span>
      </div>
    </a>
  </div>
</BaseLayout>

<script>
  // IntersectionObserver for scroll animations
  const sections = document.querySelectorAll('.section');
  const hero = document.querySelector('.hero');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('is-visible');
    });
  }, { root: null, rootMargin: '0px', threshold: 0.3 });

  sections.forEach(section => observer.observe(section));

  window.addEventListener('load', () => {
    hero.classList.add('is-visible');
    sections.forEach(section => observer.observe(section));

    // Service item background images + click to toggle intro (mobile)
    const serviceItems = document.querySelectorAll('.service-item');
    serviceItems.forEach(item => {
      const imageUrl = item.getAttribute('data-bg-url');
      if (imageUrl) {
        item.style.setProperty('--bg-url', `url(${imageUrl})`);
      }
      item.addEventListener('click', function() {
        this.classList.toggle('is-active');
      });
    });
  });
</script>
